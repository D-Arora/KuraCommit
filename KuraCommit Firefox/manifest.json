{
  "manifest_version": 3,
  "name": "KuraCommit",
  "version": "1.1",
  "description": "Manually mark KuraCloud activities as done.",
  "permissions": ["storage"],
  "host_permissions": ["*://syd1.lt.app/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "kuracommit-public@d-arora.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://syd1.lt.app/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}
